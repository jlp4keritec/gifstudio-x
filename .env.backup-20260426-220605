# ===========================
# GifStudio-X - .env (racine monorepo)
# ===========================
# Copier en .env et remplir les valeurs.
# NE JAMAIS commit .env dans Git.

# Database (PostgreSQL natif Windows)
DATABASE_URL="postgresql://gifstudio_x:admin@localhost:5432/gifstudio_x?schema=public"

# API
API_PORT=4003
API_HOST=localhost
NODE_ENV=development

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=24h
BCRYPT_COST=12
# false en dev (pas de forcage changement mdp au 1er login), true en prod
FORCE_PASSWORD_CHANGE=false

# Admin seed (first launch only)
ADMIN_EMAIL=admin@gifstudio-x.local
ADMIN_PASSWORD=AdminX123

# Storage (local disk)
STORAGE_ROOT=./storage
MAX_UPLOAD_SIZE_MB=500
MAX_VIDEO_DURATION_SECONDS=600

# CORS
CORS_ORIGIN=http://localhost:3003

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4003/api/v1

# Instance mode (private = desactive partage public / SEO / embed anonyme)
INSTANCE_MODE=private
INSTANCE_NAME=gifstudio-x

