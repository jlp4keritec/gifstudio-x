# ============================================================================
# GifStudio-X - Configuration de production (Docker)
# ============================================================================
# Genere automatiquement par bootstrap-vps.ps1 avec des secrets forts.
# NE JAMAIS commiter le fichier .env.production reel.
# ============================================================================

# --- URL publique (HTTPS imperatif) ---
PUBLIC_URL=https://gifstudio.toolspdf.net

# --- PostgreSQL (interne au reseau Docker) ---
POSTGRES_USER=gifstudio_x
POSTGRES_PASSWORD=CHANGE_ME_RANDOM_STRONG_PASSWORD
POSTGRES_DB=gifstudio_x

# --- JWT (au moins 32 caracteres aleatoires) ---
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING_AT_LEAST_32_CHARS

# --- Admin initial (cree au premier seed) ---
ADMIN_EMAIL=admin@gifstudio.toolspdf.net
ADMIN_PASSWORD=CHANGE_ME_AT_FIRST_LOGIN
FORCE_PASSWORD_CHANGE=true

# --- Storage (chemin sur le VPS pour les fichiers persistants) ---
STORAGE_PATH=/var/www/gifstudio-x/storage

# --- Limites upload ---
MAX_UPLOAD_SIZE_MB=500
MAX_VIDEO_DURATION_SECONDS=600

# --- Crawler Rule34 (optionnel) ---
RULE34_API_KEY=
RULE34_USER_ID=
